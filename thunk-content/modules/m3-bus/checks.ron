[
    // --- Lesson 01: wires and voltage ---
    Choice(
        id: CheckId("m3-01-high"),
        prompt: "A wire between two chips is carrying a high voltage. How is that read?",
        options: [
            "as a 0",
            "as a 1",
            "as the end of a byte",
        ],
        answer: 1,
    ),
    Choice(
        id: CheckId("m3-01-serial"),
        prompt: "What does it mean to send a byte serially?",
        options: [
            "all eight bits travel at once, one wire per bit",
            "the byte travels as one higher voltage level",
            "the eight bits travel one at a time over one wire",
        ],
        answer: 2,
    ),
    Choice(
        id: CheckId("m3-01-spi"),
        prompt: "How does SPI reach a device like a display?",
        options: [
            "over a small handful of wires, classically four signals",
            "over one wire that carries clock and data together",
            "over eight data wires, one for each bit of a byte",
        ],
        answer: 0,
    ),

    // --- Lesson 02: clock and data ---
    Choice(
        id: CheckId("m3-02-clock"),
        prompt: "What does the clock wire tell the receiving device?",
        options: [
            "what time of day it is",
            "which device is being spoken to",
            "when to read the data wire",
        ],
        answer: 2,
    ),
    Choice(
        id: CheckId("m3-02-perbyte"),
        prompt: "How many clock ticks does it take to move one byte?",
        options: ["one", "sixteen", "eight"],
        answer: 2,
    ),
    Short(
        id: CheckId("m3-02-msb"),
        prompt: "By convention, which bit of the byte is sent first on SPI? (name it, or use the abbreviation)",
        answers: [
            "most significant",
            "most significant bit",
            "msb",
            "the most significant bit",
            "the msb",
            "bit 7",
            "the high bit",
            "high bit",
        ],
    ),

    // --- Lesson 03: chip select ---
    Choice(
        id: CheckId("m3-03-select"),
        prompt: "What does a chip select wire do?",
        options: [
            "it tells one device that the bus traffic is for it",
            "it carries the data bits out to the device",
            "it sets how fast the clock is allowed to tick",
        ],
        answer: 0,
    ),
    Short(
        id: CheckId("m3-03-controller"),
        prompt: "What is the device that drives the clock called? (one word)",
        answers: ["controller", "the controller"],
    ),
    Choice(
        id: CheckId("m3-03-low"),
        prompt: "Chip select is usually active low. What does that mean?",
        options: [
            "the wire is pulled low to speak to the device",
            "the wire is pulled high to speak to the device",
            "the device only listens at low clock speeds",
        ],
        answer: 0,
    ),

    // --- Lesson 04: reading a trace ---
    Short(
        id: CheckId("m3-04-analyzer"),
        prompt: "What instrument records the wires over time and draws them as rows? (two words)",
        answers: [
            "logic analyzer",
            "a logic analyzer",
            "analyzer",
            "logic analyser",
            "a logic analyser",
        ],
    ),
    Choice(
        id: CheckId("m3-04-decode"),
        prompt: "How do you decode a byte out of a trace?",
        options: [
            "measure exactly how high the data line goes",
            "read the data line at each clock tick",
            "count the number of edges on the select line",
        ],
        answer: 1,
    ),
    Choice(
        id: CheckId("m3-04-trace"),
        prompt: "How does thunk's simulator record what your code puts on the bus?",
        options: [
            "as a screenshot of the panel",
            "as a trace of the bus traffic",
            "as a copy of your Rust source code",
        ],
        answer: 1,
    ),
]
