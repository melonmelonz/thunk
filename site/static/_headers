# Cloudflare Pages headers for the thunk course SPA.
# No external origins: the site is self-contained (self-hosted fonts, in-repo
# wasm). script-src carries 'wasm-unsafe-eval' for the bench module (the
# thunk-sim WebAssembly build). 'unsafe-inline' is kept for the SvelteKit
# hydration bootstrap and injected styles, since adapter-static prerenders
# without CSP hashing; it does not widen the origin allowlist. Verify the live
# site after the next deploy before tightening further.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY

# The DOOM finale assets (module, engine, WAD, source offer) are content-
# addressed by their committed bytes and only fetched when the bench source
# switch flips to DOOM. Cache them hard so a returning player never re-downloads
# the ~9.8MB (gzipped) WAD. Same-origin, so they load under the CSP above.
/doom/*
  Cache-Control: public, max-age=31536000, immutable
