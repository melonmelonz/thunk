{
	"name": "site",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"wasm": "wasm-pack build wasm --target bundler --out-dir pkg --out-name thunk_wasm",
		"predev": "node scripts/build-info.mjs && npm run wasm",
		"dev": "vite dev",
		"prebuild": "node scripts/build-info.mjs && npm run wasm",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "node scripts/build-info.mjs && (svelte-kit sync || echo '')",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-wasm": "^3.6.0",
		"wasm-pack": "^0.15.0"
	}
}
