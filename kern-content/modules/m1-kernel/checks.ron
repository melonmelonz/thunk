[
    Choice(
        id: CheckId("m1-01-privilege"),
        prompt: "Which processor mode is allowed to change page tables and talk to devices directly?",
        options: [
            "user mode",
            "kernel mode",
        ],
        answer: 1,
    ),
    Short(
        id: CheckId("m1-01-syscall"),
        prompt: "What is the name for the controlled doorway a program uses to ask the kernel for something? (one word is fine)",
        answers: [
            "syscall",
            "system call",
        ],
    ),
    Choice(
        id: CheckId("m1-01-owns"),
        prompt: "Which of these does the kernel own and manage?",
        options: [
            "the color theme of your text editor",
            "the scheduler and the page tables",
            "the contents of a program's source file",
        ],
        answer: 1,
    ),
]
